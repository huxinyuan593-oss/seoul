# BTC Testnet3 — Real on-chain anchoring configuration
AUDIT_BTC_NETWORK=testnet
AUDIT_BTC_RPC_URL=http://testnet-node:18332
AUDIT_BTC_RPC_USER=admin
AUDIT_BTC_RPC_PASSWORD=admin

# Database
AUDIT_DATABASE_URL=postgresql+asyncpg://audit:audit@postgres:5432/audit_db

# Redis
AUDIT_REDIS_URL=redis://redis:6379/1

# Merkle batch interval (daily)
AUDIT_MERKLE_BATCH_INTERVAL_HOURS=24

# Audit verification (hourly)
AUDIT_AUDIT_VERIFICATION_INTERVAL_MINUTES=60
